{
  "manifest_version": 3,
  "name": "RadioDash",
  "version": "1.0",
  "description": "Radiologist Dashboard",
  "permissions": ["activeTab", "downloads", "scripting", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": ["http://*/*", "https://*/*"]
}
