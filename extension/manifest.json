{
  "manifest_version": 3,
  "name": "RadioDash",
  "version": "1.0",
  "description": "Radiologist Dashboard",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": ["http://localhost:5000/*"]
}
